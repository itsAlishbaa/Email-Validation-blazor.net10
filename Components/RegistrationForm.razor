@page "/register"
@using BlazorApp.Models

<div class="form-container">
    <div class="form-card">
        <div class="form-header">
            <h2>Create Account</h2>
            <p>Please fill out the details below</p>
        </div>

        <EditForm Model="@User" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="firstName">First Name</label>
                <InputText id="firstName" @bind-Value="User.FirstName" class="form-control" />
                <ValidationMessage For="@(() => User.FirstName)" class="error-message" />
            </div>

            <div class="form-group">
                <label for="lastName">Last Name</label>
                <InputText id="lastName" @bind-Value="User.LastName" class="form-control" />
                <ValidationMessage For="@(() => User.LastName)" class="error-message" />
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <InputText id="email" type="email" @bind-Value="User.Email" class="form-control" />
                <ValidationMessage For="@(() => User.Email)" class="error-message" />
            </div>

            <button type="submit" class="btn-submit">Submit Registration</button>
        </EditForm>

        @if (isSubmissionSuccessful)
        {
            <div class="success-banner">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                </svg>
                <span>Registration submitted successfully!</span>
            </div>
        }
    </div>
</div>

@code {
    private UserModel User { get; set; } = new();
    private bool isSubmissionSuccessful = false;

    private void HandleValidSubmit()
    {
        isSubmissionSuccessful = true;
    }
}